# Email Notifier Configuration
# Copy this file to .env and fill in your values

# ===========================================
# EMAIL PROVIDER SETTINGS
# ===========================================

# Choose one: smtp, sendgrid, aws_ses
EMAIL_PROVIDER=smtp

# --- SMTP Configuration (Gmail, etc.) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# --- SendGrid Configuration ---
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# --- AWS SES Configuration ---
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-east-1

# ===========================================
# EMAIL RECIPIENTS
# ===========================================

EMAIL_TO=scoffie@example.com
EMAIL_FROM=your-email@gmail.com
# EMAIL_CC= (optional)

# ===========================================
# SCHEDULE SETTINGS (EST/EDT - New York)
# ===========================================

SCHEDULE_TIMEZONE=America/New_York

# Daily report at 5:00 PM EST
DAILY_REPORT_HOUR=17
DAILY_REPORT_MINUTE=0

# Weekly report on Sunday at 5:00 PM EST
WEEKLY_REPORT_DAY=6
WEEKLY_REPORT_HOUR=17
WEEKLY_REPORT_MINUTE=0

# Monthly report on last day at 5:00 PM EST
MONTHLY_REPORT_HOUR=17
MONTHLY_REPORT_MINUTE=0

# ===========================================
# DATABASE PATHS
# ===========================================

# Path to webhook-receiver SQLite database
EMAIL_NOTIFIER_DB_PATH=../webhook-receiver/data/alerts.db

# Path to analysis-engine OHLCV database
EMAIL_NOTIFIER_OHLCV_DB_PATH=../analysis-engine/ohlcv.db

# ===========================================
# APPLICATION SETTINGS
# ===========================================

LOG_LEVEL=INFO
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY_SECONDS=60
REPORT_LOOKBACK_DAYS=30
TOP_SYMBOLS_LIMIT=10

# ===========================================
# ANALYSIS ENGINE (Optional)
# ===========================================

# If analysis engine is running as separate service
# ANALYSIS_ENGINE_URL=http://localhost:8001
