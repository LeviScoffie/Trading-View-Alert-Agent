# TradingView Alert Agent - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Webhook Receiver Configuration
# =============================================================================

# Secret key for validating incoming TradingView webhook requests
# Generate a strong random string (e.g., openssl rand -base64 32)
WEBHOOK_SECRET=your_webhook_secret_here

# Path to SQLite database for storing alerts
DATABASE_PATH=/app/data/alerts.db

# =============================================================================
# Analysis Engine Configuration
# =============================================================================

# Path to SQLite database for OHLCV data
OHLCV_DB_PATH=/app/data/ohlcv.db

# Moving Average period for calculations (number of periods)
MA_PERIOD=20

# Confidence threshold for signal generation (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.75

# =============================================================================
# Email Notifier Configuration
# =============================================================================

# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_or_smtp_password

# Recipient email address for alerts
EMAIL_TO=recipient@example.com

# =============================================================================
# Scheduler Configuration
# =============================================================================

# Timezone for scheduled tasks (e.g., UTC, America/New_York, Europe/London)
TIMEZONE=UTC

# Path to schedule configuration JSON file
SCHEDULE_CONFIG=/app/config/schedule.json

# =============================================================================
# Global Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Example Schedule Config File (create at ./scheduler/config/schedule.json)
# =============================================================================
