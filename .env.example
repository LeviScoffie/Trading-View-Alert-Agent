#   "jobs": [
#     {
#       "name": "hourly_analysis",
#       "schedule": "0 * * * *",
#       "endpoint": "/api/analyze",
#       "payload": {"timeframe": "1h"}
#     },
#     {
#       "name": "daily_report",
#       "schedule": "0 9 * * *",
#       "endpoint": "/api/report",
