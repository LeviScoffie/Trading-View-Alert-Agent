# TradingView Webhook Receiver Configuration

# Server settings
HOST=0.0.0.0
PORT=8000

# Database settings
DATABASE_PATH=data/alerts.db

# Logging
LOG_LEVEL=INFO

# Optional: Webhook secret for basic validation
# WEBHOOK_SECRET=your-secret-here

# Analysis — confidence threshold for immediate alert emails (0.0–1.0)
# An email fires when the analysis engine returns confidence >= this value
CONFIDENCE_THRESHOLD=0.75
